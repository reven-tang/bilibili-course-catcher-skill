# B 站课程抓取技能 - 环境变量配置示例
# 复制此文件为 .env 并填入真实值

# ============================================
# B 站配置
# ============================================

# B 站 Cookie（可选，用于需要登录的接口）
# 获取方式：登录 B 站后，从浏览器开发者工具复制 Cookie
# 格式：SESSDATA=xxx; bili_jct=xxx; ...
BILIBILI_COOKIE=

# ============================================
# 请求配置
# ============================================

# 请求超时时间（毫秒），默认 30000
REQUEST_TIMEOUT=30000

# 最大重试次数，默认 3
MAX_RETRIES=3

# ============================================
# 日志配置
# ============================================

# 日志级别：debug | info | warn | error
LOG_LEVEL=info

# ============================================
# 使用说明
# ============================================
# 1. 复制此文件：cp .env.example .env
# 2. 填入真实值（BILIBILI_COOKIE 可选）
# 3. 技能会自动加载 .env 文件中的配置
#
# 注意：.env 文件应加入 .gitignore，不要提交到版本控制
